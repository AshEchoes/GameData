		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["text"] = "[size 17]一手搭上长剑，一手虚抚上颈圈封印，地上的影子忠诚地反馈着他的动作。",
			["text_align"] = "center",
		},
