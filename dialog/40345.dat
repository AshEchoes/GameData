			["material"] = "M_UI_SpinePortrait",
			["path"] = "n82ourea/n82ourea_fox_03_action1",
		},
		["text"] = "……你来……干什么……",
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.55294120311737,
						0.67058825492859,
						1.0,
						1.0,
					},
					["lens"] = {
						["attrs"] = {
							["CF_MakeBottom_Dialog"] = 0.0,
							["F_ScreenLightness"] = 1.2,
							["F_ScreenSaturation"] = 0.3,
						},
						["in_time"] = 0,
						["is_loop"] = true,
						["material"] = "MI_UI_SaturationLightness",
					},
				},
				["path"] = "interface/resource/Game/Dialog04SceneBG/bg_Inanna_11.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]独属于野兽的低吼自喉中传出，\n\n牢房里，一个矮小的兽耳少年正蜷缩在地面一角，\n\n脖颈和四肢被闪着冷光的锁链缠绕，金色的花纹游走在其上，\n\n警惕着罪人的一举一动。",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 200,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "FB2634004E1CAEEE6719039A7FE2DC1C",
		["guid_str"] = "0C2rSgsA",
		["id"] = 3,
		["speaker_info"] = {
