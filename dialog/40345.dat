		["guid_str"] = "NsfZUZUz",
		["id"] = 2,
		["name"] = "狄戈亚",
		["speaker_info"] = {
			["anim"] = "normal",
			["color"] = {
				0.0,
				0.0,
				0.0,
				0.62745100259781,
