		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]云无月轻轻移动鼠标，没有点开，只是右键点击删除。\n\n既是因为习惯了注目，也是因为不想因过度在意而耗费心力。",
			["text_align"] = "center",
		},
