			["height"] = 200,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17][indent][indent][indent]【Berserker】在这种斗争里，付出最多代价的反而是普通人，比如姐姐救下的那个小女孩……",
			["tween"] = {
