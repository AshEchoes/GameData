			["is_only_append_separate_tween"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[br][br][size 17][indent][indent][indent]【Berserker】如果你父亲有内部消息的渠道的话就该知道，现在冲突的双方没有哪边是在为了普通人行动。",
			["tween"] = {
