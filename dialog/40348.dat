	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog02SceneBG/bg_room_04.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17]刚走到琴房门口，就听见里面传来熟悉的旋律。",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 500,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "58EFCCE5453AE9F31B005D9B1CD00D8A",
		["guid_str"] = "48fe90BN",
		["id"] = 201,
	},
	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog02SceneBG/bg_room_04.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17]云无月没有敲门，而是无声地拧动门把手走了进去。\n\n弹琴的人背对着门口，正心无旁骛地演奏着，她靠在门边，只是倾听。\n",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 500,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "24BB5539448F7EEE11E94C8D85218D26",
		["guid_str"] = "yrF7GF3p",
		["id"] = 202,
	},
	{
