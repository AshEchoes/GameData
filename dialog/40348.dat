		["id"] = 7,
		["name"] = "云无月",
		["text"] = "嗯？",
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.58663058280945,
						0.68460732698441,
						0.96279072761536,
						1.0,
					},
				},
				["path"] = "interface/resource/Game/Dialog03SceneBG/bg_room_14_beforefire.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]电脑屏幕的弹窗提示收到了一条消息，来自陌生人。",
			["text_align"] = "center",
		},
		["characters"] = {
			{
				["anim"] = "surprise",
				["blur"] = {
					["material"] = "M_UI_SpineBlur",
				},
				["material"] = "M_UI_SpineMat",
				["path"] = "af27ywy/af27ywy_child_action1",
				["pos"] = {
					0,
					250,
				},
				["scale"] = {
					0.93999999761581,
					0.93999999761581,
				},
				["shadow"] = {
					["material"] = "M_UI_SpineShadow",
				},
				["tween"] = {
					{
						["param"] = {
							["delay"] = 0,
							["time"] = 400,
						},
						["tween"] = "FadeOut",
					},
				},
			},
		},
		["guid"] = "4F34762D42E36BF8FA75E690FB50CA0E",
		["guid_str"] = "SqAJyL7C",
		["id"] = 8,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.58663058280945,
						0.68460732698441,
						0.96279072761536,
						1.0,
					},
				},
				["path"] = "interface/resource/Game/Dialog03SceneBG/bg_room_14_beforefire.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]从第一次登台开始，云无月就收到了很多来自听众的关注，\n\n除了雪片一般的粉丝来信，社交媒体中数量众多等待通过的好友申请。\n\n也不乏有人提出想要私下见面的邀请。",
			["text_align"] = "center",
		},
		["guid"] = "186D0CA4449FE04436805E928C6FABB3",
		["guid_str"] = "71eCAVM1",
		["id"] = 9,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.58663058280945,
						0.68460732698441,
						0.96279072761536,
						1.0,
					},
				},
				["path"] = "interface/resource/Game/Dialog03SceneBG/bg_room_14_beforefire.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]对此，作为监护人的休伯特自然是持全面否定的态度一一回绝，\n\n也曾尝试过委托保镖公司和信息安全公司，减少对私人空间的侵占。",
			["text_align"] = "center",
		},
		["guid"] = "28106B5B42F96662188C67B5DA215C08",
		["guid_str"] = "ApNWuhRa",
		["id"] = 10,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.58663058280945,
						0.68460732698441,
						0.96279072761536,
						1.0,
					},
				},
				["path"] = "interface/resource/Game/Dialog03SceneBG/bg_room_14_beforefire.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]然而事实是在当下这个世界里，前者或许还具有一定的威慑力，\n\n但保护个人隐私实在不是一件易事。",
			["text_align"] = "center",
		},
		["guid"] = "819E4B274AB8288BEE49ABB2535038C5",
		["guid_str"] = "ZA63ZgTM",
		["id"] = 11,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["color"] = {
						0.58663058280945,
						0.68460732698441,
						0.96279072761536,
						1.0,
					},
				},
				["path"] = "interface/resource/Game/Dialog03SceneBG/bg_room_14_beforefire.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]低调的行事作风并不能完全抵挡来自他人的好奇，总有人能通过各种渠道取得云无月的私人联系方式——\n\n就像眼下这样，哪怕用于注册账号的号码和资料都是伪造的。\n",
			["text_align"] = "center",
		},
		["guid"] = "E113A3F24CB97E711B5AEC8116756B08",
		["guid_str"] = "6th6Fx6V",
		["id"] = 12,
	},
