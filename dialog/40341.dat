		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]又来了，这种态度——",
			["text_align"] = "center",
		},
		["guid"] = "E1E6E66E4343B70875DDC5B434FFDC27",
		["guid_str"] = "BzUputcu",
		["id"] = 92,
	},
	{
		["bg_info"] = {
