					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]方才溜走的烦躁和小情绪又涌了回来，弗雷德里克感觉一股难言的火气直冲向大脑，忘了还摊开的手，猛地握起砸向桌面。",
			["text_align"] = "center",
		},
