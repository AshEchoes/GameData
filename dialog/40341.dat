					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]弗雷德里克忽然注意到，他的课本里下还放着另一本书。",
			["text_align"] = "center",
		},
		["guid"] = "1E1B68A749552F922F26EAB9AD1B4CDD",
		["guid_str"] = "XvLqaxHT",
