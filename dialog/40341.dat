		["guid"] = "6AAC0EAD4226BB126BE0FC9F5980ADC7",
		["guid_str"] = "hiFaaIlc",
		["id"] = 89,
		["name"] = "弗雷德里克·L·达弗戴尔",
		["text"] = "你原来在偷偷看别的！",
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["video"] = {
						["is_queue"] = true,
					},
				},
				["path"] = "",
			},
			{
				["config"] = {
					["video"] = {
