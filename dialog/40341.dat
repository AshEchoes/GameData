				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]他们就是反驳刚刚那些理论最好的证据！",
			["text_align"] = "center",
		},
		["guid"] = "311DE7EF420172FE69FC02A01CE90A72",
		["guid_str"] = "IX0myhpx",
