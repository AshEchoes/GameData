						["is_queue"] = true,
						["path"] = "movies/Desktop/avg/activity_ruvia/ssr0008_loop.mp4",
					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]弗雷德里克没仔细听，也没加入任何讨论，一错不错盯着空中那团精湛的魔法。",
			["text_align"] = "center",
		},
		["guid"] = "30D56C1B41136CB5B9123FB66CFDED31",
		["guid_str"] = "XBEK1rXn",
		["id"] = 83,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["video"] = {
						["is_queue"] = true,
					},
				},
				["path"] = "",
			},
			{
				["config"] = {
					["video"] = {
						["count"] = -1,
						["is_queue"] = true,
						["path"] = "movies/Desktop/avg/activity_ruvia/ssr0008_loop.mp4",
					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]是的，是的，他怎么就忘记了，怎么就沉浸在那些小情绪里，明明那个人，还有这个人——",
			["text_align"] = "center",
		},
		["guid"] = "D7BBB3334C54E5A557855D9B65D69780",
		["guid_str"] = "iefXNK5v",
		["id"] = 84,
	},
	{
