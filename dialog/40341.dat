		["guid"] = "68CDFB244CFE32692111D69A05F01E82",
		["guid_str"] = "8gGhJ48t",
		["id"] = 82,
		["name"] = "研修院学徒D",
		["text"] = "说实话，我现在宁愿相信那个传闻……他真的和「圣冕」大人有关还更好接受一点……否则……真的太残酷了，唉……",
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["video"] = {
						["is_queue"] = true,
					},
				},
				["path"] = "",
			},
			{
				["config"] = {
