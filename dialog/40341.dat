						["is_queue"] = true,
						["path"] = "movies/Desktop/avg/activity_ruvia/ssr0008_loop.mp4",
					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]像是发现了了不得的把柄，弗雷德里克在需要压低的声音里放出最大的音量，因为不自觉的“兴奋”甚至险些破音。",
			["text_align"] = "center",
		},
		["guid"] = "69EA1D9F4E337D47128E0EAF194EA8D4",
		["guid_str"] = "GenmR3TU",
		["id"] = 90,
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["video"] = {
						["is_queue"] = true,
					},
				},
				["path"] = "",
			},
			{
				["config"] = {
					["video"] = {
						["count"] = -1,
						["is_queue"] = true,
						["path"] = "movies/Desktop/avg/activity_ruvia/ssr0008_loop.mp4",
					},
				},
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]洛特斯终于有了反应，但他没话说，只是稍微朝着声音的方向侧过脸，再没其他任何多余的动作，\n\n弗雷德里克却从中读出了“挑衅”和“不屑”。",
			["text_align"] = "center",
		},
		["guid"] = "6F5D48674A8ABFE382BAB893C9480D8E",
		["guid_str"] = "8GHwTw7z",
		["id"] = 91,
	},
	{
		["bg_info"] = {
