		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]身边又路过几个像是第一次玩完射击还在兴奋中的年轻人，\n\n看见门廊下站着明显未成年的小孩子还自来熟地打了招呼。",
			["text_align"] = "center",
