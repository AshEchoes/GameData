		["just_auto_play"] = true,
	},
	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog08SceneBG/bg_city_street_06.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]午后阳光炙烈，一名少年站在颇有派头的俱乐部门口，\n\n笔挺的白衬衫夹在其他结伴而来的客人中间显得格格不入。",
			["text_align"] = "center",
		},
		["guid"] = "EFFB15DA4E655446DEF7D0B0C9E957E2",
		["guid_str"] = "2rqn8rO3",
