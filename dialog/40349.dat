		["guid"] = "CE824F0D4A9E7E5FA60C7C82AAB7E009",
		["guid_str"] = "D3GmxGZq",
		["id"] = 18,
	},
	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog08SceneBG/bg_city_street_06.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_show_all"] = true,
			["mask_alpha"] = 0.80000001192093,
			["text"] = "[indent][indent][size 17]「爸」你到了找家店坐一会儿，我大概半小时后到。\n\n[indent][indent]「玄戈」好的，路上小心。",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 500,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "0E6AAD9044C9B34895A636A42CADAC01",
		["guid_str"] = "Ndm4QBog",
		["id"] = 19,
	},
	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog08SceneBG/bg_city_street_06.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]结果还是在早上被临时叫去处理一份档案，一直到这个时间才勉强能走开。",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 500,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "63D335EC43F353B4D520A0BF54D6BFE5",
		["guid_str"] = "VStAmjoL",
		["id"] = 20,
	},
	{
