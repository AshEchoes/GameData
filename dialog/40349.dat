	{
		["bg_info"] = {
			{
				["path"] = "interface/resource/Game/Dialog08SceneBG/bg_city_street_06.png",
			},
			{
			},
		},
		["caption_info"] = {
			["align"] = "bottom",
			["b_use_mask"] = true,
			["text"] = "[size 17]下午两点半，时间刚刚好。",
			["text_align"] = "center",
		},
		["characters"] = {
			{
				["anim"] = "normal",
