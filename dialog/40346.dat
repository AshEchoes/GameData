		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]像是好不容易出笼的鸟儿，又像是终于找到一个安全的地方，弗雷德里克再次拿出匣子爱不释手。\n\n[size 17]卡徒路斯没再试图找到暴露的发梢，他也重新将目光投向艾特纳之匣。",
			["text_align"] = "center",
		},
