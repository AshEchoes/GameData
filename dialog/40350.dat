			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17]由于行业的特殊性，鹿路运输很少迎来全面的休息，\n\n但也永远带着散不掉的散漫和悠闲，总有人换班，也总有人聚在一起叽叽喳喳。",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 400,
					},
