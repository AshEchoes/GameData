		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17][c ffff66]【比赛实况】[/c]\n\n[font zhunyuan]第三轮打序，神枭队阿仁投手的球路渐渐被抓住，\n\n但大幅度快速下坠的曲线球仍未被攻破，是会选择塞满垒解决五棒，还是正面迎击，\n\n这场无论看点还是时长都已经超出一般准决赛的攻防战还在持续——",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["am"] = 15,
						["delay"] = 0,
						["duration"] = 500,
