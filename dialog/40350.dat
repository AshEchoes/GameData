					},
				},
				["path"] = "interface/resource/Game/DialogActivitySceneBG/bg_gate_dininghall_01.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17]比赛已经在一来一回的消息中重新开始，可能是天气太好，空调太舒服，也可能是晚睡早起害得人犯懒，\n\n北洛动动手指敲了几下，顺手把消息提示关了专心看起了最后两局直播。",
			["text_align"] = "center",
		},
