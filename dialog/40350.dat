							["tween"] = "RelativePositionChange",
						},
					},
				},
				["path"] = "interface/resource/Game/DialogActivitySceneBG/bg_gate_dininghall_01.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17][c ffff66]【比赛实况】[/c]\n\n[font zhunyuan]这场准决赛已来到末盘——七局下半二出局一三垒有人，\n\n只要一记安打不动星队就可再次扩大比分，\n\n清打线的恐怖袭击究竟能不能延续，神枭队恐怕正面临本场比赛中最大的危机！",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["am"] = 15,
						["delay"] = 0,
						["duration"] = 500,
						["time"] = 25,
					},
					["tween"] = "Shake",
				},
			},
		},
		["guid"] = "87019061478311AEAF31238B01DCE512",
		["guid_str"] = "0qvXARJb",
		["id"] = 5,
