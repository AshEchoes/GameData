							["tween"] = "RelativePositionChange",
						},
					},
				},
				["path"] = "interface/resource/Game/DialogActivitySceneBG/bg_gate_dininghall_01.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17]北洛拧着眉毛盯着信息里乱七八糟的称呼。\n\n自从因亲人意外到来得知自己的真实身世，经历短暂的“失意”迅速振作起来后，无咎整只鸟就愈发“无法无天”，\n\n唐路遥甚至还担心过打火机有一天会不会失去本来的作用，把他们的几年家业通通带走再背上一辈子还不清的债务。",
			["text_align"] = "center",
		},
		["guid"] = "B2BF1C70471FE2B8F9AAEFBAF29C6458",
		["guid_str"] = "Uu02IpaD",
		["id"] = 41,
		["speaker_info"] = {
			["anim"] = "scornful",
			["material"] = "M_UI_SpinePortrait",
			["path"] = "am30bl/am30bl_action1",
		},
	},
	{
		["bg_info"] = {
			{
				["config"] = {
					["tween"] = {
						{
							["param"] = {
