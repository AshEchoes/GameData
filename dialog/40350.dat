			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.60000002384186,
			["text"] = "[size 17][c ffff66]【比赛实况】[/c]\n\n[font zhunyuan]现在上场的是这赛季已经打出12记全垒打，\n\n本场比赛也在缠斗11球后成功轰出2分逆转安打的不动星队四棒——维森选手！",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["am"] = 15,
						["delay"] = 0,
						["duration"] = 500,
						["time"] = 25,
					},
					["tween"] = "Shake",
				},
			},
			["tween_bg"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 400,
					},
					["tween"] = "FadeIn",
				},
			},
		},
		["guid"] = "754200B04C5B71749C72E58B770F79A1",
