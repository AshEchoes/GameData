			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]路远抬头扫过去，就看到远处被围得水泄不通的周边贩售区，\n\n排队的队伍已经折返了6圈，远远只能看到一个标识了队尾处的牌子。",
			["text_align"] = "center",
			["tween"] = {
