				},
				["path"] = "interface/resource/Game/Dialog08SceneBG/bg_school_15.png",
			},
			{
			},
		},
		["caption_info"] = {
			["b_use_mask"] = true,
			["is_separate_tween"] = true,
			["mask_alpha"] = 0.5,
			["text"] = "[size 17]每次看着琳琅满目的商品，\n\n路远都要庆幸PUNK ROSY成立第一天就全员投票通过——\n\n“如无特殊需求不采用选手高清大脸照制作任何贩售商品”这一公约。",
			["text_align"] = "center",
			["tween"] = {
				{
					["param"] = {
						["delay"] = 0,
						["time"] = 400,
					},
